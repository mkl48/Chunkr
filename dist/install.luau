--
--   world:Cutout(cframe, Chunkr.Stencils.star(), 8, 3)        -- star hole
--   world:Cutout(cframe, Chunkr.Stencils.text("BOOM"), Vector2.new(14, 4), 3)
--   Chunkr.Stencils.custom({ "..##..", ".####.", "######" })  -- your own
--
