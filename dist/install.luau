function Network.startClient()
	Dispatch.Compose(OP, nil, "Strict")
	Dispatch.Compose(FX, nil, "Lazy")
	table.insert(subscriptions, Dispatch.Subscribe(FX, function(payload: any)
		Events.OnFx:Fire(payload)
	end))
