local Hooks = {}

local preHooks: {[string]: {(any) -> any}} = {}
local postHooks: {[string]: {(any) -> any}} = {}

local function append(store: {[string]: {(any) -> any}}, name: string, hook: (any) -> any)
	local list = store[name]
	if not list then
		list = {}
		store[name] = list
	end
	table.insert(list, hook)
end

