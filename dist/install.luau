end

function Reaction:_dispatch()
	return Promise.new(function(resolve, reject)
		self._reject = reject

		local ok, result = pcall(self._attempt)

		if self._cancelled then
			reject("cancelled")
			return
		end

		if ok then
			resolve(result)
			return
		end

		if self._retriesLeft > 0 then
			self._retriesLeft -= 1
			self:_dispatch():andThen(resolve, reject)
			return
		end

		reject(result)
	end)
end

