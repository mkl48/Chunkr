		quarks[name] = definition
		return
	end

	local legacy = LEGACY_PRIMITIVES[definition]
	assert(legacy, string.format("[Substance] Quark '%s': invalid type '%s'", name, tostring(definition)))
	quarks[name] = legacy()
end

