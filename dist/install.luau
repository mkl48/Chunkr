		Dispatch.Broadcast(FX, { t = "crumble", p = position, m = material and material.name, n = count })
	end)
	Events.OnSplit:Connect(function(body, fragments)
		Dispatch.Broadcast(FX, { t = "split", p = body:GetPivot().Position, n = #fragments })
	end)
