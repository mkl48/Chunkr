local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local IS_SERVER = RunService:IsServer()

local CLASS_BY_TYPE = {
	Lazy = "UnreliableRemoteEvent",
	Strict = "RemoteEvent",
	Solve = "RemoteFunction",
