							buffer.writeu8(brokenFlags, index, 1)
						end
						-- Everything below now only carries what's under the
						-- break; restart the accumulation.
						load = 0
					else
						load += densityLut[id] or 0
					end
				end
			end
		end
	end

	return broken
end

return Stress
