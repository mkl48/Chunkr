--
-- Split rule for ANCHORED bodies (the neighborhood-disconnector behaviour):
-- islands still touching the ground layer stay anchored - the largest keeps
-- the body, other grounded islands become new anchored bodies. Ungrounded
-- islands fall as dynamic assemblies. Slice a standing pane in half and the
-- top half drops while the bottom keeps standing, whichever is bigger.

local RunService = game:GetService("RunService")

local Workers = require(script.Parent.Workers)
local Body = require(script.Parent.Parent._Classes.Body)
local Volume = require(script.Parent.Parent._Classes.Volume)
local Anchor = require(script.Parent.Parent._Classes.Anchor)
local Joint = require(script.Parent.Parent._Classes.Joint)
local Materials = require(script.Parent.Parent._Patterns.Materials)
local Fracture = require(script.Parent.Parent._Patterns.Fracture)
local Impact = require(script.Parent.Parent._Patterns.Impact)
local Fire = require(script.Parent.Parent._Patterns.Fire)
local Carve = require(script.Parent.Parent._Patterns.Carve)
local Debris = require(script.Parent.Parent._Patterns.Debris)
local Topology = require(script.Parent.Parent._Patterns.Topology)
local Grid = require(script.Parent.Parent._Utility.Grid)
local Events = require(script.Parent.Parent._Utility.Events)
local Bin = require(script.Parent.Parent._Utility.Bin)

local Simulation = {}

local connection: RBXScriptConnection? = nil
local rand: () -> number = Grid.rng(os.time())
local lastDespawnSweep = 0

local function strengthLut(): { [number]: number }
	local lut = {}
	for id, material in Materials.all() do
		lut[id] = material.strength
	end
	return lut
end

local function densityLut(): { [number]: number }
	local lut = {}
	for id, material in Materials.all() do
		lut[id] = material.density
	end
	return lut
end

-- An island of an anchored body is grounded when it still touches the source
-- volume's bottom layer (tight bounds make this a min-y check).
local function isGrounded(island: Topology.Island): boolean
	return island.oy == 0
end

local function fragmentVelocity(world: any, body: Body.Body, island: Topology.Island, sourcePivot: CFrame, sourceVelocity: Vector3): Vector3
	local velocity = sourceVelocity
	local lastFracture = body._lastFracture
	if lastFracture and os.clock() - lastFracture.at < 1 then
		local impact = world.config.impact
		local fragmentCenter = sourcePivot:PointToWorldSpace(
			Vector3.new(island.ox + island.sx / 2, island.oy + island.sy / 2, island.oz + island.sz / 2) * body.voxelSize
		)
		local away = fragmentCenter - lastFracture.position
		if away.Magnitude > 1e-3 then
			local speed = impact.fragmentKickBase
				+ math.min(lastFracture.impulse * impact.fragmentKickScale, impact.fragmentKickMax)
			velocity += away.Unit * speed
		end
	end
	return velocity
end

-- Islands (from a Topology job) become: the kept volume on the source body,
-- new anchored bodies (grounded pieces of anchored sources), dynamic
-- fragments, or crumble events.
local function applySplit(world: any, body: Body.Body, islands: { Topology.Island })
	table.sort(islands, function(a, b)
		return a.count > b.count
	end)

	-- The kept island: for anchored bodies, the largest GROUNDED island (the
	-- part still standing); otherwise simply the largest. An anchored body
	-- with no grounded island left gets unanchored - the whole thing falls.
	local keptIndex = 1
	if body.anchored then
		local grounded = nil
		for i, island in islands do
			if isGrounded(island) then
				grounded = i
				break -- sorted by size, first grounded is the largest grounded
			end
		end
		if grounded then
			keptIndex = grounded
		else
			body:SetAnchored(false)
		end
	end
	local kept = islands[keptIndex]

	local sourcePivot = body:GetPivot()
	local sourceVelocity = if body.rootPart and not body.anchored
		then body.rootPart.AssemblyLinearVelocity
		else Vector3.zero

	body:ReplaceVolume(Volume.fromBuffer(kept.sx, kept.sy, kept.sz, kept.voxels), kept.ox, kept.oy, kept.oz)
	body.needsRemesh = true

	local spawned: { Body.Body } = {}
	for i, island in islands do
		if i == keptIndex then
			continue
		end

		-- Grounded siblings of an anchored body keep standing as their own
		-- anchored bodies; everything else is debris-classified.
		local staysAnchored = body.anchored and isGrounded(island)
		if not staysAnchored and Debris.classify(island.count, world.config.debris) == "crumble" then
			local sampleId = 0
			for j = 0, island.sx * island.sy * island.sz - 1 do
				sampleId = buffer.readu16(island.voxels, j * 2)
				if sampleId ~= 0 then
					break
				end
			end
			local center = sourcePivot:PointToWorldSpace(
				Vector3.new(island.ox + island.sx / 2, island.oy + island.sy / 2, island.oz + island.sz / 2) * body.voxelSize
			)
			Events.OnCrumble:Fire(center, Materials.byId(sampleId), island.count)
			continue
		end

		local fragment = Body.fromVolume(Volume.fromBuffer(island.sx, island.sy, island.sz, island.voxels), {
			voxelSize = body.voxelSize,
			cframe = sourcePivot * CFrame.new(Vector3.new(island.ox, island.oy, island.oz) * body.voxelSize),
			anchored = staysAnchored,
			carvable = body.carvable and (staysAnchored or Debris.isCarvable(island.count, world.config.debris)),
			-- Binned sources let fragments auto-bin (Bodys vs Chunks by
			-- anchored state); explicitly parented sources pass it down.
			parent = if Bin.isBin(body.model.Parent) then nil else body.model.Parent,
		})
		if staysAnchored then
			fragment._stressDirty = true
		else
			fragment._pendingVelocity = fragmentVelocity(world, body, island, sourcePivot, sourceVelocity)
		end
		fragment.needsRemesh = true
		world:Add(fragment)
		table.insert(spawned, fragment)

		-- Rehome anchors whose host voxel moved into this fragment.
		for j = #body.anchors, 1, -1 do
			local anchor = body.anchors[j]
			local ix, iy, iz = anchor.x - island.ox, anchor.y - island.oy, anchor.z - island.oz
			if
				ix >= 0 and iy >= 0 and iz >= 0 and ix < island.sx and iy < island.sy and iz < island.sz
				and fragment.volume:Get(ix, iy, iz) ~= 0
			then
				Anchor.Migrate(anchor, fragment, island.ox, island.oy, island.oz)
			end
		end
	end

	-- Kept-island offset shifts the surviving anchors' coordinates.
	if kept.ox ~= 0 or kept.oy ~= 0 or kept.oz ~= 0 then
		for _, anchor in body.anchors do
			anchor.x -= kept.ox
			anchor.y -= kept.oy
			anchor.z -= kept.oz
		end
	end

	if #spawned > 0 then
		Events.OnSplit:Fire(body, spawned)
	end
	if body.anchored then
		body._stressDirty = true
	end
end

local function step(world: any)
	local config = world.config

	-- 1. Impact events -> crack stamping / dent chipping (+ momentum keep).
	for _, event in Impact.drain() do
		local body = event.body
		if body.destroyed or not body.carvable then
			continue
		end
		if event.kind == "dent" then
			local removed = Carve.sphere(body.volume, event.x + 0.5, event.y + 0.5, event.z + 0.5, event.radius or 1)
			if removed > 0 then
				Events.OnCarve:Fire(body, body:LocalToWorld(event.x, event.y, event.z), (event.radius or 1) * body.voxelSize, removed)
			end
			continue
		end
		local pattern, removed, detachLabels = Fracture.apply(body.volume, event, rand)
		if removed > 0 or detachLabels then
			Events.OnFracture:Fire(event, pattern)
			if detachLabels then
				body._pendingDetach = detachLabels
			end
			if event.position then
				body._lastFracture = { position = event.position, impulse = event.impulse, at = os.clock() }
			end
			local impactor = event._impactor
			if impactor and impactor.Parent then
				impactor.AssemblyLinearVelocity = event._impactorVelocity
			end
		end
	end

	-- 2. Dirty volumes (or pending detach labels) -> Topology. Detach passes
	-- the fracture's region labels as split barriers: nothing was deleted,
	-- the pieces just come apart.
	for _, body in world:Bodies() do
		if body.destroyed or body._topoInFlight or (not body.volume.dirty and not body._pendingDetach) then
			continue
		end
		local volume = body.volume
		volume:ClearDirty()
		local detachLabels = body._pendingDetach
		body._pendingDetach = nil
		body._topoInFlight = true

		if volume:IsEmpty() then
			body._topoInFlight = false
			world:Remove(body)
			continue
		end

		local snap = buffer.create(buffer.len(volume.voxels))
		buffer.copy(snap, 0, volume.voxels, 0)
		Workers.dispatch("topology", function(islands)
			body._topoInFlight = false
			if body.destroyed then
				return
			end
			-- Stale result: volume changed while the job flew; dirty flag is
			-- set again so the next tick re-runs.
			if body.volume ~= volume or volume.dirty then
				return
			end
			if #islands <= 1 then
				body.needsRemesh = true
				if body.anchored then
					body._stressDirty = true
				end
			else
				applySplit(world, body, islands)
			end
		end, snap, volume.sx, volume.sy, volume.sz, detachLabels)
	end

	-- 3. Stress budget: anchored bodies flagged since their last check.
	if config.stress.enabled then
		local budget = config.stress.bodiesPerTick
		for _, body in world:Bodies() do
			if budget <= 0 then
				break
			end
			if not body._stressDirty or body.destroyed or not body.anchored or body._topoInFlight then
				continue
			end
			budget -= 1
			body._stressDirty = false

			local volume = body.volume
			-- Grounding rule v1: solid voxels on the bottom layer. TODO:
			-- contact-based grounding for bodies resting on other anchored bodies.
			local seeds = {}
			for z = 0, volume.sz - 1 do
				for x = 0, volume.sx - 1 do
					if volume:Get(x, 0, z) ~= 0 then
						table.insert(seeds, x + z * volume.sx)
					end
				end
			end
			if #seeds == 0 then
				-- Nothing grounded: the whole body falls.
				body:SetAnchored(false)
				continue
			end

			local snap = buffer.create(buffer.len(volume.voxels))
			buffer.copy(snap, 0, volume.voxels, 0)
			Workers.dispatch("stress", function(broken, warnings)
				if body.destroyed or body.volume ~= volume then
					return
				end
				local sxsz = volume.sx * volume.sz
				for _, index in broken do
					local x = index % volume.sx
					local y = index // sxsz
					local z = (index // volume.sx) % volume.sz
					volume:Set(x, y, z, 0)
				end
				-- Deleting marks dirty -> next tick's Topology drops the pieces.

				-- Groans: loaded near capacity but holding - fire the worst
				-- spot so games can creak/dust BEFORE the collapse.
				if warnings and #warnings > 0 and os.clock() - (body._lastCreak or 0) >= config.stress.creakCooldown then
					body._lastCreak = os.clock()
					local worst = warnings[1]
					for _, warning in warnings do
						if warning.severity > worst.severity then
							worst = warning
						end
					end
					local x = worst.index % volume.sx
					local y = worst.index // sxsz
					local z = (worst.index // volume.sx) % volume.sz
					Events.OnCreak:Fire(body, body:LocalToWorld(x, y, z), worst.severity, #warnings)
				end
			end, snap, volume.sx, volume.sy, volume.sz, seeds, strengthLut(), config.stress.loadFactor, densityLut(), config.stress.crushFactor, config.stress.warnRatio)
		end
	end

	-- 3.5. Fire: burn fuel down, spread, delete burnt voxels (the deletions
	-- feed step 2's topology next tick, so burnt-through pieces drop).
	if config.fire.enabled then
		Fire.step(world)
	end

	-- 4. Anchors ride their (possibly moving) bodies.
	for _, body in world:Bodies() do
		if not body.anchored and #body.anchors > 0 then
			for i = #body.anchors, 1, -1 do
				Anchor.Sync(body.anchors[i])
			end
		end
	end

	-- 4.5. Joints re-link after rebuilds/migrations, break on dead voxels.
	Joint.step()

	-- 5. Debris housekeeping, once a second.
	local now = os.clock()
	if now - lastDespawnSweep >= 1 then
		lastDespawnSweep = now
		local entries = {}
		for _, body in world:Bodies() do
			if not body.anchored then
				table.insert(entries, {
					id = body,
					ageSeconds = now - body.spawnedAt,
					sleeping = body:IsSleeping(),
				})
			end
		end
		for _, body in Debris.selectDespawn(entries, config.debris) do
			world:Remove(body)
		end
	end
end

function Simulation.start(world: any, config: any)
	rand = Grid.rng(config.seed or os.time())
	connection = RunService.Heartbeat:Connect(function()
		step(world)
	end)
end

function Simulation.stop()
	if connection then
		connection:Disconnect()
		connection = nil
	end
end

return Simulation
]])
mod("Vfx", _3, [[
-- Chunkr voxel VFX: effects built from tiny CUBE parts instead of particle
-- sprites, so debris/impacts read as voxels like everything else. Cubes are
-- pooled, anchored, and integrated by hand on Heartbeat (position + spin +
-- faked gravity) - zero physics cost, hard budget cap.
--
--   local vfx = Chunkr.client().vfx
--   vfx.burst({ position = p, color = c })            -- impact spray
--   vfx.ring({ position = p })                        -- expanding shockwave
--   local trail = vfx.trail(part, { color = c })      -- cube streak; trail.Stop()
--   vfx.dissolve({ position = p, region = size })     -- surface flakes drift off
--   vfx.rubbleRain({ position = ceiling })            -- dust-fall before collapse
--
-- The stock FX pack drives these automatically from destruction events with
-- Chunkr.client().fx.start({ voxels = true }). Client only.

local RunService = game:GetService("RunService")

local Vfx = {}

export type BurstOptions = {
	position: Vector3,
	color: Color3?,
	count: number?,
	speed: number?,
	size: number?,
	lifetime: number?,
	-- Bias cone: cubes fly within `spread` degrees of this direction.
	direction: Vector3?,
	spread: number?,
	-- Gravity multiplier (default 1).
	gravity: number?,
}

export type RingOptions = {
	position: Vector3,
	color: Color3?,
	count: number?,
	speed: number?,
	size: number?,
	lifetime: number?,
	-- Ring plane normal (default up = ground shockwave).
	normal: Vector3?,
}

export type TrailOptions = {
	color: Color3?,
	size: number?,
	-- Seconds between cubes (default 0.05).
	interval: number?,
	lifetime: number?,
}

export type DissolveOptions = {
	position: Vector3,
	-- Box region the flakes spawn throughout.
	region: Vector3,
	color: Color3?,
	count: number?,
	size: number?,
	lifetime: number?,
}

export type RainOptions = {
	position: Vector3,
	-- Horizontal spawn area (default 8 x 8 studs).
	area: Vector2?,
	color: Color3?,
	count: number?,
	size: number?,
	lifetime: number?,
}

export type Trail = {
	Stop: (self: Trail) -> (),
}

type Cube = {
	part: Part,
	position: Vector3,
	rotation: CFrame,
	velocity: Vector3,
	angular: Vector3,
	gravity: number,
	age: number,
	life: number,
}

type TrailState = {
	follow: BasePart,
	options: TrailOptions,
	accumulator: number,
	stopped: boolean,
}

local DEFAULT_BUDGET = 150
local GRAY = Color3.fromRGB(150, 143, 136)

local pool: { Part } = {}
local active: { Cube } = {}
local trails: { TrailState } = {}
local connection: RBXScriptConnection? = nil
local budget = DEFAULT_BUDGET
local rng = Random.new()

-- ---------------------------------------------------------------- lifecycle

local function acquirePart(): Part
	local part = table.remove(pool)
	if part then
		return part
	end
	local fresh = Instance.new("Part")
	fresh.Name = "ChunkrVfx"
	fresh.Anchored = true
	fresh.CanCollide = false
	fresh.CanQuery = false
	fresh.CanTouch = false
	fresh.CastShadow = false
	fresh:SetAttribute("ChunkrIgnore", true)
	return fresh
end

local function releaseCube(index: number)
	local cube = active[index]
	active[index] = active[#active]
	active[#active] = nil
	local part = cube.part
	if #pool < 64 then
		part.Parent = nil
		part.Transparency = 0
		table.insert(pool, part)
	else
		part:Destroy()
	end
end

local function step(dt: number)
	local gravity = workspace.Gravity
	for i = #active, 1, -1 do
		local cube = active[i]
		cube.age += dt
		if cube.age >= cube.life or cube.position.Y < workspace.FallenPartsDestroyHeight + 100 then
			releaseCube(i)
			continue
		end
		cube.velocity -= Vector3.new(0, gravity * cube.gravity * dt, 0)
		cube.position += cube.velocity * dt
		local spin = cube.angular * dt
		cube.rotation = cube.rotation * CFrame.fromEulerAnglesXYZ(spin.X, spin.Y, spin.Z)
		local part = cube.part
		part.CFrame = CFrame.new(cube.position) * cube.rotation
		-- Fade out over the last 40% of life.
		local fadeFrom = cube.life * 0.6
		if cube.age > fadeFrom then
			part.Transparency = (cube.age - fadeFrom) / (cube.life - fadeFrom)
		end
	end

	for i = #trails, 1, -1 do
		local trail = trails[i]
		local follow = trail.follow
		if trail.stopped or follow.Parent == nil then
			trails[i] = trails[#trails]
			trails[#trails] = nil
			continue
		end
		trail.accumulator += dt
		local interval = trail.options.interval or 0.05
		if trail.accumulator >= interval then
			trail.accumulator = 0
			Vfx.burst({
				position = follow.Position,
				color = trail.options.color,
				count = 1,
				speed = 1.5,
				size = trail.options.size or 0.3,
				lifetime = trail.options.lifetime or 0.8,
				gravity = 0.15,
			})
		end
	end

	if #active == 0 and #trails == 0 and connection then
		connection:Disconnect()
		connection = nil
	end
end

local function ensureRunning()
	if not connection then
		connection = RunService.Heartbeat:Connect(step)
	end
end

local function spawnCube(position: Vector3, velocity: Vector3, color: Color3, size: number, life: number, gravityScale: number)
	if #active >= budget then
		return
	end
	local part = acquirePart()
	part.Size = Vector3.one * size
	part.Color = color
	part.Transparency = 0
	local rotation = CFrame.fromEulerAnglesXYZ(rng:NextNumber(0, math.pi), rng:NextNumber(0, math.pi), rng:NextNumber(0, math.pi))
	part.CFrame = CFrame.new(position) * rotation
	part.Parent = workspace
	table.insert(active, {
		part = part,
		position = position,
		rotation = rotation,
		velocity = velocity,
		angular = Vector3.new(rng:NextNumber(-8, 8), rng:NextNumber(-8, 8), rng:NextNumber(-8, 8)),
		gravity = gravityScale,
		age = 0,
		life = life * rng:NextNumber(0.7, 1.15),
	})
	ensureRunning()
end

-- Slight per-cube tint variation so a spray doesn't read as one flat colour.
local function vary(color: Color3): Color3
	local f = rng:NextNumber(0.85, 1.1)
	return Color3.new(math.clamp(color.R * f, 0, 1), math.clamp(color.G * f, 0, 1), math.clamp(color.B * f, 0, 1))
end

-- ---------------------------------------------------------------- emitters

function Vfx.burst(options: BurstOptions)
	local count = options.count or 24
	local speed = options.speed or 18
	local size = options.size or 0.4
	local life = options.lifetime or 1.2
	local color = options.color or GRAY
	local gravityScale = options.gravity or 1
	local direction = options.direction
	local spread = math.rad(options.spread or 60)
	for _ = 1, count do
		local dir
		if direction then
			-- Random direction within the cone around `direction`.
			local axis = direction.Unit
			local ortho = axis:Cross(if math.abs(axis.Y) < 0.9 then Vector3.yAxis else Vector3.xAxis).Unit
			local tilt = rng:NextNumber(0, spread)
			local roll = rng:NextNumber(0, math.pi * 2)
			dir = (CFrame.fromAxisAngle(axis, roll) * CFrame.fromAxisAngle(ortho, tilt)):VectorToWorldSpace(axis)
		else
			dir = rng:NextUnitVector()
		end
		local cubeSize = size * rng:NextNumber(0.6, 1.4)
		spawnCube(options.position, dir * speed * rng:NextNumber(0.4, 1), vary(color), cubeSize, life, gravityScale)
	end
end

function Vfx.ring(options: RingOptions)
	local count = options.count or 20
	local speed = options.speed or 14
	local size = options.size or 0.35
	local life = options.lifetime or 0.9
	local color = options.color or GRAY
	local normal = (options.normal or Vector3.yAxis).Unit
	local ortho = normal:Cross(if math.abs(normal.Y) < 0.9 then Vector3.yAxis else Vector3.xAxis).Unit
	for i = 1, count do
		local angle = (i / count) * math.pi * 2 + rng:NextNumber(-0.1, 0.1)
		local dir = (CFrame.fromAxisAngle(normal, angle)):VectorToWorldSpace(ortho)
		local velocity = dir * speed * rng:NextNumber(0.85, 1.1) + normal * speed * 0.12
		spawnCube(options.position + dir * 0.5, velocity, vary(color), size * rng:NextNumber(0.7, 1.3), life, 0.35)
	end
end

-- Cube streak following a part (flying debris, projectiles). Auto-stops when
-- the part leaves the world; call `:Stop()` to end it early.
function Vfx.trail(follow: BasePart, options: TrailOptions?): Trail
	local state: TrailState = {
		follow = follow,
		options = options or {},
		accumulator = 0,
		stopped = false,
	}
	table.insert(trails, state)
	ensureRunning()
	return {
		Stop = function(_self: Trail)
			state.stopped = true
		end,
	}
end

-- Flakes drift up and off a region - use where a surface is dissolving
-- (burning walls, despawning debris).
function Vfx.dissolve(options: DissolveOptions)
	local count = options.count or 16
	local size = options.size or 0.3
	local life = options.lifetime or 1.6
	local color = options.color or GRAY
	local half = options.region / 2
	for _ = 1, count do
		local at = options.position + Vector3.new(
			rng:NextNumber(-half.X, half.X),
			rng:NextNumber(-half.Y, half.Y),
			rng:NextNumber(-half.Z, half.Z)
		)
		local velocity = Vector3.new(rng:NextNumber(-1.5, 1.5), rng:NextNumber(1.5, 3.5), rng:NextNumber(-1.5, 1.5))
		spawnCube(at, velocity, vary(color), size * rng:NextNumber(0.6, 1.2), life, -0.02)
	end
end

-- Cubes shake loose from a ceiling area and fall - the tension beat before
-- a collapse (pairs with OnCreak).
function Vfx.rubbleRain(options: RainOptions)
	local count = options.count or 12
	local size = options.size or 0.3
	local life = options.lifetime or 2
	local color = options.color or GRAY
	local area = options.area or Vector2.new(8, 8)
	for _ = 1, count do
		local at = options.position + Vector3.new(rng:NextNumber(-area.X / 2, area.X / 2), rng:NextNumber(-0.4, 0), rng:NextNumber(-area.Y / 2, area.Y / 2))
		local velocity = Vector3.new(rng:NextNumber(-0.5, 0.5), rng:NextNumber(-2, 0), rng:NextNumber(-0.5, 0.5))
		spawnCube(at, velocity, vary(color), size * rng:NextNumber(0.5, 1.3), life, rng:NextNumber(0.6, 1))
	end
end

-- ---------------------------------------------------------------- control

-- Max simultaneous cubes (shared across all emitters). Default 150.
function Vfx.setBudget(count: number)
	budget = math.max(count, 0)
end

-- Kill every live cube and trail immediately.
function Vfx.stop()
	for i = #active, 1, -1 do
		active[i].part:Destroy()
		active[i] = nil
	end
	table.clear(trails)
	if connection then
		connection:Disconnect()
		connection = nil
	end
end

