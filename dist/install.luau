				local dx, dy, dz = x + 0.5 - cx, y + 0.5 - cy, z + 0.5 - cz
				if dx * dx + dy * dy + dz * dz <= r2 then
					local id = volume:Get(x, y, z)
					if id ~= 0 then
						table.insert(out, { x = x, y = y, z = z, id = id })
					end
				end
			end
		end
	end
	return out
end

