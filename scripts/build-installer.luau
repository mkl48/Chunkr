-- Generates dist/install.luau: a single, self-contained script that recreates the entire
-- Chunkr module tree (folders + ModuleScripts with embedded source) under
-- ReplicatedStorage when pasted into the Roblox Studio command bar. The real .luau files
-- in src/ are the ONE source of truth - run `lune run scripts/build-installer` to refresh.
--
-- Mapping: src/init.luau -> ModuleScript "Chunkr"; src/X.luau -> child ModuleScript "X";
-- src/Y/init.luau -> child ModuleScript "Y" (with its own children); a folder without an
-- init.luau becomes a Folder. Chunkr-specific: *.server.luau files install as Scripts with
-- RunContext = Server and Enabled = false (the Workers actor Runner template); *.meta.json
-- carries their Rojo properties and is skipped here. Source is embedded as a long-bracket
-- string with a safe `=` level (see longString below), so it reads verbatim.

local fs = require("@lune/fs")

local SRC = "src"
local OUT_DIR = "dist"
local OUT = OUT_DIR .. "/install.luau"
local BOOT = OUT_DIR .. "/bootstrap.luau"
-- Raw URL the bootstrap fetches the full installer from. Adjust the branch if needed.
local RAW_URL = "https://raw.githubusercontent.com/mkl48/Chunkr/master/dist/install.luau"

local body: { string } = {}
local function emit(line: string)
	table.insert(body, line)
end

local counter = 0
local function nextVar(): string
	counter += 1
	return "_" .. counter
end

-- A short Luau string literal for a simple value (module names).
local function q(s: string): string
	return string.format("%q", s)
end

-- Embed arbitrary Luau source as a long-bracket string [==[ ... ]==], picking an `=` level
-- whose closing bracket doesn't occur in the source. Long strings take NO escapes, so the
-- code is embedded verbatim and reads cleanly - the right tool for porting source. A
-- leading newline is added (Luau strips exactly one after the open bracket) so source that
-- begins with `[` or a newline survives intact.
local function longString(s: string): string
	local level = 0
	while string.find(s, `]{string.rep("=", level)}]`, 1, true) do
		level += 1
	end
	local eq = string.rep("=", level)
	return `[{eq}[\n{s}]{eq}]`
end

local function isDir(path: string): boolean
	local ok = pcall(fs.readDir, path)
	return ok
end

local function exists(path: string): boolean
	local ok = pcall(fs.readFile, path)
	return ok
end

local moduleCount = 0
local folderCount = 0
local scriptCount = 0

-- A module folder is one with an init.lua / init.luau (vendored deps use .lua).
local function moduleInit(dir: string): string?
	for _, name in { "init.luau", "init.lua" } do
		local path = dir .. "/" .. name
		if exists(path) then
			return path
		end
	end
	return nil
end

-- Worker actor templates ship as disabled Server-RunContext Scripts.
local function isServerScript(entry: string): boolean
	return string.match(entry, "%.server%.luau?$") ~= nil
end

-- A bundlable ModuleScript source file: *.lua / *.luau, excluding init,
-- server/client scripts (handled separately) and spec/story files.
local function isSourceFile(entry: string): boolean
	if entry == "init.lua" or entry == "init.luau" then
		return false
	end
	if string.find(entry, "%.client%.") or string.find(entry, "%.server%.") then
		return false
	end
	if string.find(entry, "%.spec%.") or string.find(entry, "%.story%.") then
		return false
	end
	return string.match(entry, "%.luau?$") ~= nil
end

-- Emit the creation of `dir` as a node parented to `parentVar`, then recurse. Returns the
-- local variable name bound to the created instance (so children can parent to it).
local function build(dir: string, parentVar: string, name: string): string
	local var = nextVar()
	local init = moduleInit(dir)

	if init then
		moduleCount += 1
		emit(`local {var} = mod({q(name)}, {parentVar}, {longString(fs.readFile(init))})`)
	else
		folderCount += 1
		emit(`local {var} = folder({q(name)}, {parentVar})`)
	end

	local entries = fs.readDir(dir)
	table.sort(entries)
	for _, entry in entries do
		local path = dir .. "/" .. entry
		if isDir(path) then
			build(path, var, entry)
		elseif isServerScript(entry) then
			scriptCount += 1
			local childName = string.gsub(entry, "%.server%.luau?$", "")
			emit(`srv({q(childName)}, {var}, {longString(fs.readFile(path))})`)
		elseif isSourceFile(entry) then
			moduleCount += 1
			local childName = string.gsub(entry, "%.luau?$", "")
			emit(`mod({q(childName)}, {var}, {longString(fs.readFile(path))})`)
		end
	end

	return var
end

build(SRC, "RS", "Chunkr")

local header = [[
-- Chunkr installer - GENERATED by scripts/build-installer.luau. Do not edit by hand.
--
-- Paste this whole script into the Roblox Studio command bar to (re)install Chunkr into
-- ReplicatedStorage. A previous install named "Chunkr" is replaced.
--
-- Dependencies ARE bundled: Signal, Promise and Substance are vendored under _Packages
-- (attribution in their sources), so they install as children of the Chunkr module.
-- Nothing else to add.

local RS = game:GetService("ReplicatedStorage")

local function mod(name, parent, source)
	local m = Instance.new("ModuleScript")
	m.Name = name
	m.Source = source
	m.Parent = parent
	return m
end

local function folder(name, parent)
	local f = Instance.new("Folder")
	f.Name = name
	f.Parent = parent
	return f
end

-- Worker actor template: disabled Server-RunContext Script, cloned under
-- Actors at runtime by _Main/Workers.
local function srv(name, parent, source)
	local s = Instance.new("Script")
	s.Name = name
	s.Source = source
	s.RunContext = Enum.RunContext.Server
	s.Enabled = false
	s.Parent = parent
	return s
end

local old = RS:FindFirstChild("Chunkr")
if old then
	old:Destroy()
end
]]

-- `return true` lets the bootstrap's require-fallback run the installer as a ModuleScript.
local footer = `\nprint("[Chunkr] installed {moduleCount} modules ({scriptCount} scripts) under ReplicatedStorage.Chunkr")\nreturn true\n`

pcall(fs.writeDir, OUT_DIR)
fs.writeFile(OUT, header .. "\n" .. table.concat(body, "\n") .. "\n" .. footer)

-- The tiny bootstrap: paste THIS into the command bar instead of the huge installer. It
-- HTTP-fetches the installer and runs it (loadstring if available, else a temp ModuleScript
-- require). Needs Game Settings -> Security -> Allow HTTP Requests = ON.
local bootstrap = [[
-- Chunkr bootstrap - paste into the Roblox Studio command bar.
-- Fetches and runs the full installer over HTTP (no giant paste).
-- Requires: Game Settings -> Security -> Allow HTTP Requests = ON.
local HttpService = game:GetService("HttpService")
local URL = "]] .. RAW_URL .. [["

local ok, body = pcall(function()
	return HttpService:GetAsync(URL)
end)
if not ok then
	warn("[Chunkr] HTTP fetch failed (enable Allow HTTP Requests in Game Settings): " .. tostring(body))
	return
end

if loadstring then
	local fn, err = loadstring(body)
	if fn then
		fn()
		return
	end
	warn("[Chunkr] loadstring failed, trying ModuleScript fallback: " .. tostring(err))
end

local m = Instance.new("ModuleScript")
m.Name = "ChunkrInstaller"
m.Source = body
m.Parent = game:GetService("ReplicatedStorage")
local okr, err = pcall(require, m)
m:Destroy()
if not okr then
	warn("[Chunkr] install failed: " .. tostring(err))
end
]]
fs.writeFile(BOOT, bootstrap)

print(`Wrote {OUT} ({moduleCount} modules, {scriptCount} scripts, {folderCount} folders) and {BOOT}.`)
